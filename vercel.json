{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "thuisaccu-gids.nl" }],
      "destination": "https://www.thuisaccu-gids.nl/:path*",
      "permanent": true
    }
  ]
}
