# Kopieer naar .env.local en vul in na goedkeuring partnerprogramma's.
# .env.local staat in .gitignore — nooit committen met echte ID's.

# Bol Partner → Site ID uit partner.bol.com
NEXT_PUBLIC_BOL_PARTNER_ID=

# Amazon Associates NL → Store-ID (bijv. thuisaccugids-21)
NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=

# Awin deeplink-templates — {url} = encoded product-URL (Link Builder)
# Bluetti EU via Awin (programma 95479) — Link Builder → template met {url}
NEXT_PUBLIC_BLUETTI_AFFILIATE_URL=
NEXT_PUBLIC_COOLBLUE_AFFILIATE_URL=
NEXT_PUBLIC_MEDIAMARKT_AFFILIATE_URL=
NEXT_PUBLIC_CONRAD_AFFILIATE_URL=

# Google Search Console → HTML-tag verificatie (alleen de code, zonder prefix)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
